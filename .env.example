# ============================================================
# FlowEngine Configuration
# ============================================================

# -- Server --
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
DATABASE_PATH=./data/flowengine.db
API_KEY=

# -- Logging --
LOG_LEVEL=INFO
LOG_DIR=./logs

# -- Worker --
SERVER_URL=http://localhost:8080
WORKER_ID=worker-1
POLL_INTERVAL_SEC=5
MAX_CONCURRENT_JOBS=1

# -- Chrome / Profiles --
CHROME_USER_DATA_DIR=./profiles
FLOW_PROFILE_LIST_FILE=./profiles_ultra.txt
CHROME_PATH=
# FLOW_REAL_CHROME=1          # Use native Chrome via CDP (Windows default)
# FLOW_USE_BASE_PROFILE=1     # Don't clone profile (use directly)
# FLOW_ACTION_DELAY_MS=800    # Playwright slow_mo
FLOW_BROWSER_POOL=1           # Reuse Chrome across jobs per profile (~12-15s saved/job)

# -- Flow Automation --
FLOW_DOWNLOAD_DIR=./downloads
FLOW_DOWNLOAD_QUALITY=1080p
FLOW_UPSCALE_MAX_WAIT_SEC=180
FLOW_UPSCALE_POLL_INTERVAL_SEC=10
# FLOW_MEDIA_FETCH_ENABLED=0  # Default off: /api/media/fetch-url uses yt-dlp and has residual SSRF/rebind risk

# -- Docker --
# IS_DOCKER=1                 # Set in Dockerfile, don't set manually
