# FlowEngine Configuration
# Copy this to .env and customize

# === Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DATABASE_PATH=./data/flowengine.db
API_KEY=change-me-to-a-secure-key

# === Worker ===
SERVER_URL=http://localhost:8000
WORKER_ID=worker-1
CHROME_USER_DATA_DIR=C:/Users/YourName/AppData/Local/Google/Chrome/User Data
WORKER_PROFILES=profile1,profile2
POLL_INTERVAL_SEC=5
MAX_CONCURRENT_JOBS=1

# === Flow Automation ===
FLOW_DOWNLOAD_QUALITY=1080p
FLOW_UPSCALE_MAX_WAIT_SEC=180
FLOW_GENERATION_TIMEOUT_SEC=900
FLOW_EXTEND_TIMEOUT_SEC=600
FLOW_EDIT_TIMEOUT_SEC=300
FLOW_UPSCALE_POLL_INTERVAL_SEC=10
