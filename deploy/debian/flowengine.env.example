# FlowEngine — production env (copy to /etc/flowengine/flowengine.env)
# chown root:flowengine /etc/flowengine/flowengine.env && chmod 0640 ...
# All values are read by uvicorn / FastAPI via os.getenv.

# ----- Required: rotate before exposing to the internet ----------------------

# Bearer token the WORKER uses to call /api/worker/* on this server.
# Generate with: openssl rand -hex 32
API_KEY=CHANGE_ME_BEFORE_DEPLOY

# ----- Persistence paths -----------------------------------------------------

# SQLite database (jobs, profiles). systemd unit ReadWritePaths covers this.
DATABASE_PATH=/var/lib/flowengine/flowengine.db

# Where the worker uploads originals + Flow downloads land. The server
# mounts these dirs as /uploads and /downloads — make sure the worker
# (Windows host) and this server agree on a way to reach them. Easiest:
# share the directory over SMB or sync via rclone; advanced: NFS.
FLOW_DOWNLOAD_DIR=/var/lib/flowengine/downloads
FLOW_UPLOAD_DIR=/var/lib/flowengine/uploads

# ----- Logging ---------------------------------------------------------------

LOG_DIR=/var/log/flowengine
LOG_LEVEL=INFO
