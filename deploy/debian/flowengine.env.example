# FlowEngine — production env (copy to /etc/flowengine/flowengine.env)
# chown root:flowengine /etc/flowengine/flowengine.env && chmod 0640 ...
# All values are read by uvicorn / FastAPI via os.getenv.

# ----- Required: rotate before exposing to the internet ----------------------

# Bearer token the WORKER uses to call /api/worker/* on this server.
# Generate with: openssl rand -hex 32
API_KEY=CHANGE_ME_BEFORE_DEPLOY

# ----- Persistence paths -----------------------------------------------------

# SQLite database (jobs, profiles). systemd unit ReadWritePaths covers this.
DATABASE_PATH=/var/lib/flowengine/flowengine.db

# Where the worker uploads originals + Flow downloads land. The server
# mounts these dirs as /uploads and /downloads — make sure the worker
# (Windows host) and this server agree on a way to reach them. Easiest:
# share the directory over SMB or sync via rclone; advanced: NFS.
FLOW_DOWNLOAD_DIR=/var/lib/flowengine/downloads
FLOW_UPLOAD_DIR=/var/lib/flowengine/uploads

# ----- Multi-site / CORS -----------------------------------------------------

# Comma-separated allowlist of frontend origins that may call /api and /ws.
# Default "*" (or unset) keeps the API open — fine while API_KEY gates
# /api/worker/* and the dashboard endpoints are intentionally public.
# Lock down in production by listing the real frontend origins:
#   ALLOWED_ORIGINS=https://ai.hassio.io.vn,https://ai.ciem,https://flow.your-host
# When a non-wildcard list is given, allow_credentials flips to true so
# cookies + Authorization headers can ride along. Browsers reject "*"
# combined with credentials, so the toggle is automatic.
ALLOWED_ORIGINS=*

# ----- Logging ---------------------------------------------------------------

LOG_DIR=/var/log/flowengine
LOG_LEVEL=INFO

# ----- Hybrid reverseAPI (Setup 2: BALANCED — speed + UI fallback safety) ----
# These env vars enable hybrid mode: engine captures the Flow POST template
# from a live UI submit, then replays the next op via API. UI fallback runs
# automatically if revAPI fails (recaptcha / rate-limit). Live-verified
# 2026-05-17 matrix (9 cate × 3 mode): hybrid = same reliability as UI,
# average -10% wall on the 3 cates enabled below.
#
# Per-cate measured wall savings vs UI baseline (depth 5 chain):
#   t2v     -13%   (capture template, replay subsequent gens skip composer)
#   extend  -8%    (replay skips edit-panel + tile-click cycle at L3+)
#   remove  -17%   (skips bbox panel cycle at L3+)
#
# Skipped: f2v UI is faster (-20%), camera hybrid > revapi (-7%).
# To go pure revAPI per cate (no UI fallback), add FLOW_<CATE>_FORCE_REVERSE=1
# next to the VIA_REVERSE=1 line; transient 403 retried via PR #227.
FLOW_T2V_VIA_REVERSE=1
FLOW_EXTEND_VIA_REVERSE=1
FLOW_REMOVE_VIA_REVERSE=1
# FLOW_T2I_VIA_REVERSE=1     # optional, ~ngang UI
# FLOW_I2V_VIA_REVERSE=1     # optional, ~ngang UI
# FLOW_INSERT_VIA_REVERSE=1  # optional, -3%
# FLOW_F2V_VIA_REVERSE=1     # NOT recommended (UI faster)
# FLOW_CAMERA_VIA_REVERSE=1  # NOT recommended (UI faster than revapi)
